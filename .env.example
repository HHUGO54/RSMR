# Base de datos — Turso (producción)
# Obtener con: turso db show <nombre-db> --url
DATABASE_URL="libsql://nombre-db-usuario.turso.io"

# Token de autenticación Turso
# Obtener con: turso db tokens create <nombre-db>
DATABASE_AUTH_TOKEN="eyJ..."

# Secret para next-auth (mínimo 32 caracteres aleatorios)
# Generar con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-seguro"

# URL pública de la app (para redirecciones de auth)
NEXTAUTH_URL="https://tu-app.vercel.app"
